PROJECT_NAME={{ project_name }}
APP_ENV=development
DEBUG=false
AUTO_MIGRATE=true
STARTUP_DEPENDENCY_TOLERANCE=true
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
TRUSTED_HOSTS=["*"]
METRICS_PATH=/metrics

SECRET_KEY={{ secret_key }}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_PROVIDER={{ database_provider }}
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/industry_ai
MYSQL_URL=
MONGODB_URL=
MONGODB_DATABASE=industry_ai
CACHE_PROVIDER={{ cache_provider }}
REDIS_URL=redis://redis:6379/0
DRAGONFLY_URL=
QUEUE_PROVIDER={{ queue_provider }}
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

VECTOR_DB={{ vector_db }}
VECTORSTORE_PROVIDER={{ vector_db }}
LLM_PROVIDER={{ llm_provider }}
EMBEDDING_DIMENSIONS=64

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=documents
QDRANT_API_KEY=
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=documents
PGVECTOR_URL=
PGVECTOR_TABLE_NAME=document_embeddings
PINECONE_API_KEY=
PINECONE_INDEX_NAME=documents
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OTEL_ENABLED=false
OTEL_SERVICE_NAME=industry-ai-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
